rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny Catch-all global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard high-security helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Input data validation helper ensuring key sizes, strict fields, and owner verification to avoid spoofing
    function isValidCampaign(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'status', 'ownerId'])
        && data.id is string && data.id.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.title is string && data.title.size() <= 500
        && data.description is string && data.description.size() <= 10000
        && data.status in ['published', 'draft', 'failed'];
    }

    // Campaigns fortress rule definitions
    match /campaigns/{campaignId} {
      // Secure List / Get: Rules itself validates the resource being queried to prevent query scraping
      allow get, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      // Allow creation/modification only with solid schemas matching the authenticated user ID
      allow create: if isSignedIn() 
        && isValidId(campaignId) 
        && isValidCampaign(request.resource.data) 
        && request.resource.data.ownerId == request.auth.uid;
        
      allow update: if isSignedIn() 
        && isValidId(campaignId) 
        && isValidCampaign(request.resource.data) 
        && request.resource.data.ownerId == request.auth.uid
        && resource.data.ownerId == request.auth.uid;
      
      allow delete: if isSignedIn() 
        && isValidId(campaignId) 
        && resource.data.ownerId == request.auth.uid;
    }

    // Profiles rules: Restricted to matching authenticated owner ID
    match /profiles/{profileId} {
      allow read, write: if isSignedIn() && request.auth.uid == profileId;
    }

    // API Keys rules: Owner constraints matching authenticated owner ID
    match /api_keys/{keyId} {
      allow read, write: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
